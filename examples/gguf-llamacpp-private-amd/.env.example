# Copy to .env and fill in real values. .env is git-ignored — never commit secrets.

# Control plane (provisions the workload). Project → Tokens → create SDK token.
INFERENCEKEY_SDK_TOKEN=ik_sdk_xxxxxxxxxxxxxxxxxxxxxxxx

# Data plane (calls inference). API Keys → mint a key for the workload.
INFERENCEKEY_API_KEY=ik_live_xxxxxxxxxxxxxxxxxxxxxxxx

# The project slug you opened at cloud.inferencekey.com.
INFERENCEKEY_PROJECT=your-project-slug

# Optional: self-hosted / staging API URL. Omit to use the public API.
# INFERENCEKEY_BASE_URL=https://api.your-host.example

# Private-worker ids — this example pins to YOUR AMD R9700 box.
# Workers → your registered GPU box.
IK_WORKER_ID=wrk_xxxxxxxxxxxxxxxxxxxxxxxx
# GPU Resources → the GPU's opaque id.
IK_GPU_RESOURCE_ID=gpu_xxxxxxxxxxxxxxxxxxxxxxxx
